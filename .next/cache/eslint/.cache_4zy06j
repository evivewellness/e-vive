t":"190"},{"range":"232","text":"190"},{"alt":"161"},{"range":"233","text":"234"},{"alt":"164"},{"range":"235","text":"236"},{"alt":"167"},{"range":"237","text":"238"},{"alt":"170"},{"range":"239","text":"240"},"&apos;",[36762,36960],"E-Vive is East Africa&apos;s pioneering digital nutrition and care support platform for cancer patients, survivors, and their caregivers — founded on lived experience, clinical expertise, and compassion.","&lsquo;",[36762,36960],"E-Vive is East Africa&lsquo;s pioneering digital nutrition and care support platform for cancer patients, survivors, and their caregivers — founded on lived experience, clinical expertise, and compassion.","&#39;",[36762,36960],"E-Vive is East Africa&#39;s pioneering digital nutrition and care support platform for cancer patients, survivors, and their caregivers — founded on lived experience, clinical expertise, and compassion.","&rsquo;",[36762,36960],"E-Vive is East Africa&rsquo;s pioneering digital nutrition and care support platform for cancer patients, survivors, and their caregivers — founded on lived experience, clinical expertise, and compassion.",[40956,41210],"In 2020, Salome&apos;s father was diagnosed with stage 4 throat cancer. For months, she was his primary caregiver — navigating treatment protocols, managing pain, and desperately searching for guidance on nutrition that could support his recovery and comfort.",[40956,41210],"In 2020, Salome&lsquo;s father was diagnosed with stage 4 throat cancer. For months, she was his primary caregiver — navigating treatment protocols, managing pain, and desperately searching for guidance on nutrition that could support his recovery and comfort.",[40956,41210],"In 2020, Salome&#39;s father was diagnosed with stage 4 throat cancer. For months, she was his primary caregiver — navigating treatment protocols, managing pain, and desperately searching for guidance on nutrition that could support his recovery and comfort.",[40956,41210],"In 2020, Salome&rsquo;s father was diagnosed with stage 4 throat cancer. For months, she was his primary caregiver — navigating treatment protocols, managing pain, and desperately searching for guidance on nutrition that could support his recovery and comfort.","&quot;",[41278,41435],"&quot;I searched everywhere for practical, culturally relevant nutritional guidance for cancer patients in Kenya. I found almost nothing. That gap became E-Vive.\"","&ldquo;",[41278,41435],"&ldquo;I searched everywhere for practical, culturally relevant nutritional guidance for cancer patients in Kenya. I found almost nothing. That gap became E-Vive.\"","&#34;",[41278,41435],"&#34;I searched everywhere for practical, culturally relevant nutritional guidance for cancer patients in Kenya. I found almost nothing. That gap became E-Vive.\"","&rdquo;",[41278,41435],"&rdquo;I searched everywhere for practical, culturally relevant nutritional guidance for cancer patients in Kenya. I found almost nothing. That gap became E-Vive.\"",[41278,41435],"\"I searched everywhere for practical, culturally relevant nutritional guidance for cancer patients in Kenya. I found almost nothing. That gap became E-Vive.&quot;",[41278,41435],"\"I searched everywhere for practical, culturally relevant nutritional guidance for cancer patients in Kenya. I found almost nothing. That gap became E-Vive.&ldquo;",[41278,41435],"\"I searched everywhere for practical, culturally relevant nutritional guidance for cancer patients in Kenya. I found almost nothing. That gap became E-Vive.&#34;",[41278,41435],"\"I searched everywhere for practical, culturally relevant nutritional guidance for cancer patients in Kenya. I found almost nothing. That gap became E-Vive.&rdquo;",[41953,42120]," — the founder&apos;s broader healthcare and care-personnel placement venture — creating an ecosystem where nutritional care, direct home care, and digital health converge.",[41953,42120]," — the founder&lsquo;s broader healthcare and care-personnel placement venture — creating an ecosystem where nutritional care, direct home care, and digital health converge.",[41953,42120]," — the founder&#39;s broader healthcare and care-personnel placement venture — creating an ecosystem where nutritional care, direct home care, and digital health converge.",[41953,42120]," — the founder&rsquo;s broader healthcare and care-personnel placement venture — creating an ecosystem where nutritional care, direct home care, and digital health converge.",[44657,44673],"Today&apos;s Calories",[44657,44673],"Today&lsquo;s Calories",[44657,44673],"Today&#39;s Calories",[44657,44673],"Today&rsquo;s Calories",[47657,47736],"Complete this form and we&apos;ll reach out within 24 hours to confirm your session.",[47657,47736],"Complete this form and we&lsquo;ll reach out within 24 hours to confirm your session.",[47657,47736],"Complete this form and we&#39;ll reach out within 24 hours to confirm your session.",[47657,47736],"Complete this form and we&rsquo;ll reach out within 24 hours to confirm your session.",[53694,53695],[53694,53695],[53694,53695],[53694,53695],[53704,53705],[53704,53705],[53704,53705],[53704,53705],[55391,55542],"Whether you&apos;re a patient beginning treatment, a caregiver seeking support, or a diaspora family looking for trusted home care — E-Vive is here for you.",[55391,55542],"Whether you&lsquo;re a patient beginning treatment, a caregiver seeking support, or a diaspora family looking for trusted home care — E-Vive is here for you.",[55391,55542],"Whether you&#39;re a patient beginning treatment, a caregiver seeking support, or a diaspora family looking for trusted home care — E-Vive is here for you.",[55391,55542],"Whether you&rsquo;re a patient beginning treatment, a caregiver seeking support, or a diaspora family looking for trusted home care — E-Vive is here for you."]